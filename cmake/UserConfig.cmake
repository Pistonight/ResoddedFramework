# Configure aspects of ResoddedFramework from here

set(SEXY_USE_IMGUI ON CACHE BOOL "Enable ImGui" FORCE)
set(SEXY_USE_CONTROLLER ON CACHE BOOL "Enable the use of a controller" FORCE)
set(SEXY_CRASH_HANDLER ON CACHE BOOL "Enable the use of the crash handler" FORCE)
set(LAWN_USE_UNFINISHED_GAMEPAD_SUPPORT OFF CACHE BOOL "Enable the unfinished gamepad support" FORCE)
set(LAWN_SHOW_TERMINAL_DEBUG ON CACHE BOOL "Show terminal output in debug mode when double-clicking to start the game" FORCE)
set(LAWN_SHOW_TERMINAL_RELEASE OFF CACHE BOOL "Show terminal output in release mode when double-clicking to start the game" FORCE)
